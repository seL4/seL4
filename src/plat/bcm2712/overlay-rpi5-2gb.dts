/ {
    /delete-node/ memory;

    /* Memory for the 2GB RAM variant of the RPi5B, see overlay-pi5.dts for an
     * explanation of the memory ranges.
     */
    memory@0 {
        device_type = "memory";
        reg = < 0x00000000 0x00000000 0x0 0x3fc00000>;
    };
};
